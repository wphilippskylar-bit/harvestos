# Copy this file to .env.local and fill in your own Supabase project values.
# Get these from: Supabase dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: set to "true" to run the app against built-in demo/mock data
# with no Supabase project connected yet (great for a first look).
NEXT_PUBLIC_DEMO_MODE=false

# --- Push notifications (optional — only needed for the low-stock / harvest-due alerts) ---
# Generate a keypair with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@yourdomain.com

# A random string (16+ chars) that authorizes the daily alert cron job — see vercel.json.
# Generate one with: openssl rand -base64 24
CRON_SECRET=

# --- Service role key (optional — only needed for the alert cron job) ---
# Supabase dashboard -> Project Settings -> API -> service_role key.
# NEVER put this in NEXT_PUBLIC_* or expose it to the browser — server-only, used by
# app/api/push/send-alerts to read across every org/user, which RLS deliberately blocks otherwise.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI soil test photo extraction (optional — Fields module) ---
# Get a key from console.anthropic.com. Without this set, the "Fill in from photo" button on a
# soil test just tells the user to enter values manually — nothing else breaks.
ANTHROPIC_API_KEY=
